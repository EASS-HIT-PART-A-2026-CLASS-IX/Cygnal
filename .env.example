ABUSEIPDB_API_KEY=""
REFRESH_MAX_CONCURRENCY=4
REFRESH_MAX_ATTEMPTS=3
OLLAMA_BASE_URL=""
OLLAMA_MODEL="llama3.2:3b"
PYTHONPATH=.
