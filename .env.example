CYGNAL_APP_NAME="Cygnal"
CYGNAL_DEBUG=false
CYGNAL_API_BASE_URL="http://localhost:8000"
DATABASE_URL="sqlite:///cygnal.db"
JWT_SECRET_KEY="replace-with-a-long-random-secret"
JWT_ISSUER="cygnal-api"
JWT_AUDIENCE="cygnal-clients"
